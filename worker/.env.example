# TwinAI worker — server-side only. NEVER commit real values.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # service role — server-side only
GEMINI_API_KEY=your-gemini-key                    # for synthesis steps (later phases)

# Which job types this process drains. Normally LEAVE UNSET — the code default in
# src/env.ts is the canonical registry and tracks newly-registered types
# automatically: ingest,build_voice,scrape_dna,validate_source,editor_v2
# WORKER_JOB_TYPES=ingest,build_voice,scrape_dna,validate_source,editor_v2
WORKER_POLL_MS=3000
# Job lease. MUST exceed the hard per-job timeout (WORKER_MAX_JOB_MS, default
# 2100000ms = 35min) or a slow job gets reclaimed and DOUBLE-RUN by a peer.
WORKER_VISIBILITY_SECS=2400
WORKER_MAX_JOB_MS=2100000

# ASR
WHISPER_MODEL=base         # tiny | base | small | medium (code default: base)
WHISPER_DEVICE=cpu         # cpu | cuda
WORKER_MAX_MEDIA_SECS=900  # skip media longer than this

# Source validation (validate_source) bounds — see docs/editor-v2-source-asset.md
# SOURCE_MIN_DURATION_MS=500
# SOURCE_MAX_DURATION_MS=1800000      # 30 min hard cap for a short-form editor
# SOURCE_MAX_PIXELS=8294400           # 3840x2160 (4K); rejects decode bombs above
