# TwinAI worker — server-side only. NEVER commit real values.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # service role — server-side only
GEMINI_API_KEY=your-gemini-key                    # for synthesis steps (later phases)

# Which job types this process drains.
WORKER_JOB_TYPES=ingest,build_voice,autoedit,scrape_dna
WORKER_POLL_MS=3000
# Job lease. MUST exceed the hard per-job timeout (WORKER_MAX_JOB_MS, default
# 2100000ms = 35min) or a slow render gets reclaimed and DOUBLE-RUN by a peer.
WORKER_VISIBILITY_SECS=2400
WORKER_MAX_JOB_MS=2100000

# ASR
WHISPER_MODEL=base         # tiny | base | small | medium (code default: base)
WHISPER_DEVICE=cpu         # cpu | cuda
WORKER_MAX_MEDIA_SECS=900  # skip media longer than this

# ---- Editor value-add toggles (all OPTIONAL; unset = feature off) ----
# PEXELS_API_KEY=            # b-roll cutaways (free key: pexels.com/api)
# MUSIC_BED_URL=             # URL of a music bed MP3 -> ducked bed + beat-sync
# EDIT_EMOJI=true            # Twemoji overlays on caption moments
# EDIT_WINDOW_WHISPER=true   # real per-scene caption timing (extra whisper cost)
# REVIDEO_URL=http://172.17.0.1:4500   # premium caption render service
# REVIDEO_TRUSTED=true       # REQUIRED for the premium pass to replace the render
