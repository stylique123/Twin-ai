{
  "name": "twinai-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "TwinAI monorepo — web (Vercel), mobile (Expo/iOS), and shared code on one headless Supabase + VPS backend.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "web": "npm run dev -w @twinai/web",
    "web:build": "npm run build -w @twinai/web",
    "mobile": "npm run start -w @twinai/mobile",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
