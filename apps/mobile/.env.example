# TwinAI mobile (Expo) env — copy to .env and fill in. EXPO_PUBLIC_* values are
# bundled into the app (public by design; Row-Level Security protects the data,
# exactly like the web app's VITE_SUPABASE_* values).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
