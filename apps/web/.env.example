# TwinAI frontend env (Vite) — copy to .env.local and fill in
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase Edge Function secrets (set with: supabase secrets set ...)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-3.1-pro-preview

# Phase 2 — Brand-DNA from handle (start-dna + dna-poll edge functions)
# APIFY_TOKEN=...                                # required to scan a creator's posts
# APIFY_ACTOR_TIKTOK=clockworks~tiktok-scraper   # optional actor overrides
# APIFY_ACTOR_INSTAGRAM=apify~instagram-scraper
# APIFY_ACTOR_YOUTUBE=streamers~youtube-scraper
# DNA_POST_COUNT=20                              # posts to read per handle
